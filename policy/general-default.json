{
  "policy_version": "2026-02-01",
  "profile": "general-default",
  "repo_zone": "general",
  "category_rules": {
    "offsec": {
      "verdict": "blocked",
      "reason": "OffSec content is not allowed in General."
    }
  },
  "requires_approval_signals": [
    "uses_sudo",
    "service_control",
    "writes_system_paths",
    "chmod_chown",
    "credential_access",
    "network_download_exec",
    "shell_exec",
    "process_injection",
    "persistence"
  ],
  "default_verdict": "allowed"
}
