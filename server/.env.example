# 本地开发：复制为 .env 后按需填写；不填则走占位/mock 行为
# cp .env.example .env

# 生产模式：NODE_ENV=production 或 SKILLSCAN_MODE=production 时，SESSION_SECRET、STATE_SECRET 必填且至少 32 字符，禁止 dev/placeholder
# 本地开发可省略，用默认值；生产必须设置强密钥
# SKILLSCAN_MODE=demo

# 数据库（不设则无 DB：install/start 500、share 404、reports 占位）
# DATABASE_URL=postgres://skillscan:skillscan@localhost:5432/skillscan

HOST=0.0.0.0
PORT=3000

# state/session 签名（本地可省略，用默认；生产必改）
# STATE_SECRET=
# SESSION_SECRET=

# 分享链接域名（本地可 http://localhost:3000）
# PUBLIC_BASE_URL=http://localhost:3000

# GitHub Webhook 验签（收 webhook 时必填）
# GITHUB_WEBHOOK_SECRET=

# GitHub App（install/complete 拉 account；不设则用 mock）
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
# 本地无 App 时 mock：
# GITHUB_MOCK_ACCOUNT_ID=1
# GITHUB_MOCK_ACCOUNT_LOGIN=myorg
# GITHUB_MOCK_ACCOUNT_TYPE=Organization

# OAuth 登录（不设则 callback 会重定向带 error）
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/auth/github/callback

# /reports 验签（设 1 则跳过 cosign，用表单项 repo_full_name）
# SKIP_COSIGN_VERIFY=1

# 限流后端：memory（默认，单机）或 database（多实例共享，需要 docs/postgres-schema.sql 里的 rate_limits 表）
# RATE_LIMIT_BACKEND=database

# report schema 路径（不设则 process.cwd()/schema/report-v1.json；无文件则跳过校验）
# REPORT_SCHEMA_PATH=
